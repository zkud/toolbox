{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://192.168.1.209:11434/v1"
      },
      "models": {
        "nemotron-3-nano": {
          "name": "nemotron-3-nano hosted locally"
        }
      }
    }
  },
  "agent": {
    "developer": {
      "mode": "primary",
      "model": "ollama/nemotron-3-nano",
      "prompt": "{file:~/prompts/developer.md}",
      "tools": {
        "bash": true,
        "write": true,
        "edit": true,
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "lsp": true,
        "skill": false,
        "patch": true,
        "todowrite": true,
        "todoread": true,
        "webfetch": true,
        "websearch": false,
        "question": true
      },
      "permissions": {
        "bash": "allow",
        "write": "allow",
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "patch": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "webfetch": "allow",
        "question": "allow"
      }
    }
  }
}

